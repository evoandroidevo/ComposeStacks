#!/usr/bin/with-contenv bash
# /etc/cont-init.d/10-load-secrets
# Loads KEY=VALUE secrets from a tmpfs-backed env file into s6 container env
# so arr apps get them at service start.

set -Eeuo pipefail

# Configurable paths
SECRETS_FILE="${SECRETS_FILE:-/run/secrets/sonarr.env}" # tmpfs-mounted file
S6_ENV_DIR="/var/run/s6/container_environment"

echo "[cont-init] load-secrets: starting"

if [[ ! -d "$S6_ENV_DIR" ]]; then
mkdir -p "$S6_ENV_DIR"
fi

if [[ ! -f "$SECRETS_FILE" ]]; then
echo "[cont-init] load-secrets: no secrets file at $SECRETS_FILE (skipping)"
exit 0
fi

if [[ ! -r "$SECRETS_FILE" ]]; then
echo "[cont-init] load-secrets: secrets file is not readable: $SECRETS_FILE"
exit 1
fi

# Optional hardening: reject group/world-readable secret files
perm="$(stat -c '%a' "$SECRETS_FILE" 2>/dev/null || true)"
if [[ -n "${perm}" ]]; then
# allow 600/640 by default; adjust if you need different policy
if [[ "$perm" != "640" && "$perm" != "644" ]]; then
echo "[cont-init] load-secrets: warning: unexpected permissions $perm on $SECRETS_FILE"
fi
fi

loaded=0
line_no=0

while IFS= read -r raw || [[ -n "$raw" ]]; do
line_no=$((line_no + 1))

# Trim leading/trailing whitespace
line="${raw#"${raw%%[![:space:]]*}"}"
line="${line%"${line##*[![:space:]]}"}"

# Skip blank lines/comments
[[ -z "$line" ]] && continue
[[ "${line:0:1}" == "#" ]] && continue

# Support optional "export KEY=VALUE"
if [[ "$line" =~ ^export[[:space:]]+ ]]; then
line="${line#export }"
line="${line#"${line%%[![:space:]]*}"}"
fi

# Must contain '='
if [[ "$line" != *"="* ]]; then
echo "[cont-init] load-secrets: invalid line $line_no (missing '='): $raw"
exit 1
fi

key="${line%%=*}"
val="${line#*=}"

# Trim key/value whitespace
key="${key%"${key##*[![:space:]]}"}"
key="${key#"${key%%[![:space:]]*}"}"
val="${val#"${val%%[![:space:]]*}"}"
val="${val%"${val##*[![:space:]]}"}"

# Strip surrounding single/double quotes in value
if [[ ${#val} -ge 2 ]]; then
    if [[ "${val:0:1}" == '"' && "${val: -1}" == '"' ]]; then
      val="${val:1:${#val}-2}"
    elif [[ "${val:0:1}" == "'" && "${val: -1}" == "'" ]]; then
      val="${val:1:${#val}-2}"
    fi
  fi

  # Validate env var name
  if [[ ! "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
    echo "[cont-init] load-secrets: invalid key '$key' on line $line_no"
    exit 1
  fi

  # Write to s6 env dir (newline-safe, no echo)
  printf '%s' "$val" > "${S6_ENV_DIR}/${key}"
  loaded=$((loaded + 1))
done < "$SECRETS_FILE"

# Optional required keys check: space-delimited list in REQUIRED_SECRETS
# Example: -e REQUIRED_SECRETS="SONARR__API_KEY TZ"
if [[ -n "${REQUIRED_SECRETS:-}" ]]; then
  for req in ${REQUIRED_SECRETS}; do
    if [[ ! -f "${S6_ENV_DIR}/${req}" ]]; then
      echo "[cont-init] load-secrets: required key missing: ${req}"
      exit 1
    fi
  done
fi

echo "[cont-init] load-secrets: loaded ${loaded} secret(s) from ${SECRETS_FILE}"
exit 0